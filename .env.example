# =================================================================
# DATABASE CONFIGURATION (MYSQL)
# =================================================================
DB_ROOT_PASSWORD=your_root_password_here
DB_NAME=movie_db
DB_USERNAME=root
DB_PASSWORD=your_db_password_here
DB_PORT=3306

# =================================================================
# SERVICE PORTS
# =================================================================
BE_PORT=8080
FE_PORT=3000

# =================================================================
# REDIS CONFIGURATION
# =================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# =================================================================
# MAIL SERVICE (GMAIL SMTP)
# =================================================================
# Instructions: Use Google App Password, not your real password.
EMAIL=your_email@gmail.com
APP_PASS=your_google_app_password_16_chars

# =================================================================
# EXTERNAL SERVICES (CLOUDINARY & TMDB)
# =================================================================
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_KEY=your_cloudinary_key
CLOUDINARY_SECRET=your_cloudinary_secret

TMDB_KEY=your_tmdb_api_key_v3

# =================================================================
# SECURITY (JWT)
# =================================================================
# Generate a long random string for HS256/HS512
JWT_SECRET=your_super_secret_signing_key_at_least_32_chars
# Expiration time in milliseconds (e.g., 3600000 = 1 hour)
JWT_EXPIRATION=3600000